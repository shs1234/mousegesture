{
  "manifest_version": 3,
  "name": "Mouse Gesture",
  "version": "1.0.0",
  "description": "마우스 제스처로 브라우저를 빠르게 제어하세요. 오른쪽 클릭 + 드래그로 뒤로가기, 앞으로가기, 탭 관리 등을 수행합니다.",
  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "sessions"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
